{% extends "Base.twig" %}

{% block title %}Nový zákazník{% endblock %}

{% block content %}
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Registrace nového zákazníka</h4>
                </div>
                <div class="card-body">
                    {% if error is defined %}
                        <div class="alert alert-danger">{{ error }}</div>
                    {% endif %}

                    <form action="/customer/create" method="POST" class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Jméno</label>
                            <input type="text" class="form-control" name="first_name" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Příjmení</label>
                            <input type="text" class="form-control" name="last_name" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Telefon</label>
                            <input type="text" class="form-control" name="phone" placeholder="např. 777123456" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">E-mail</label>
                            <input type="email" class="form-control" name="email" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Město</label>
                            <input type="text" class="form-control" name="city" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">PSČ</label>
                            <input type="number" class="form-control" name="zip" required>
                        </div>
                        <div class="col-md-8">
                            <label class="form-label">Ulice (nepovinné)</label>
                            <input type="text" class="form-control" name="street">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Číslo popisné</label>
                            <input type="number" class="form-control" name="house_no" required>
                        </div>

                        <div class="col-12 text-end mt-4">
                            <a href="/repair/create" class="btn btn-outline-secondary me-2">Zrušit</a>
                            <button type="submit" class="btn btn-primary">Uložit zákazníka</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
{% endblock %}