<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <script>
        // Tento skript běží okamžitě, aby se předešlo blikání (light/dark)
        (function() {
            const storedTheme = localStorage.getItem('theme');
            const theme = storedTheme || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
            document.documentElement.setAttribute('data-bs-theme', theme);
        })();
    </script>

    {# Titulek stránky - blok pro přepsání v konkrétní šabloně #}
    <title>{% block title %}Default Title{% endblock %}</title>

    {# Zde se načítá Bootstrap CSS #}
    <link href="/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link href='https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css' rel="stylesheet">

    {# (placeholder pro dodatečné budoucí CSS) #}
    {% block stylesheets %}{% endblock %}
</head>
<body>

{# Navbar/header #}
{% block header %}
    <header>
        <div class="bg-body-tertiary border-bottom py-2">
            <div class="container d-flex align-items-center">

                <!-- 1. ČÁST: Úplně vlevo (Brand) -->
                <div style="flex: 1; display: flex; justify-content: flex-start;">
                    <a class="navbar-brand fw-bold fs-4" href="/home">Lorem ipsum</a>
                </div>

                <!-- 2. ČÁST: Uprostřed (Navigace) -->
                <div style="flex: 3; display: flex; justify-content: center;">
                    <ul class="nav">
                    {% if session.user %}
                        {% if session.user.role in ['service technician', 'receptionist', 'admin'] %}
                            <li class="nav-item"><a href="/dashboard" class="nav-link link-body-emphasis px-2">Dashboard</a></li>
                        {% endif %}

                        {% if session.user.role in ['receptionist', 'admin'] %}
                            <li class="nav-item"><a href="/invoice/browse" class="nav-link link-body-emphasis px-2">Faktury</a></li>
                            <li class="nav-item"><a href="/repair/browse" class="nav-link link-body-emphasis px-2">Záznamy oprav</a></li>
                        {% endif %}

                        {% if session.user.role in ['service technician', 'admin'] %}
                            <li class="nav-item"><a href="/repair/waiting" class="nav-link link-body-emphasis px-2">Opravy ke zpracování</a></li>
                        {% endif %}

                        {% if session.user.role == 'admin' %}
                            <li class="nav-item"><a href="/manage/employees" class="nav-link link-body-emphasis px-2">Spravovat</a></li>
                        {% endif %}
                    {% endif %}
                    </ul>
                </div>

                <!-- 3. ČÁST: Úplně vpravo (User / Logout) -->
                <div style="flex: 1; display: flex; justify-content: flex-end;">
                    <ul class="nav align-items-center">
                    {% if session.user %}
                        <li class="nav-item"><a href="/auth/logout" class="nav-link link-body-emphasis">Odhlásit se</a></li>
                        <li class="nav-item ms-2 fw-bold"> {{ session.user.role }} </li>
                    {% else %}
                        <li class="nav-item"><a href="/auth/login" class="nav-link link-body-emphasis">Přihlásit</a></li>
                    {% endif %}
                    </ul>
                </div>

            </div>
        </div>

        {# Sekudnarni navigace #}
        {% if session.user %}
        <nav class="navbar navbar-expand-lg bg-body-tertiary border-bottom" id="secondary-nav">
            <div class="container">
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNav">
                    {# Submenu Faktury #}
                    {% if session.user.role in ['receptionist', 'admin'] %}
                        <ul class="navbar-nav mx-auto mb-2 mb-lg-0 fw-semibold d-none" id="nav-invoice">
                            <li class="nav-item"><a class="nav-link px-3" href="/invoice/browse">Procházet</a></li>
                            <li class="nav-item"><a class="nav-link px-3" href="/invoice/create">Nová faktura</a></li>
                        </ul>
                    {% endif %}

                    {# Submenu Záznamy oprav #}
                    {% if session.user.role in ['receptionist', 'admin'] %}
                        <ul class="navbar-nav mx-auto mb-2 mb-lg-0 fw-semibold d-none" id="nav-repair">
                            <li class="nav-item"><a class="nav-link px-3" href="/repair/browse">Procházet</a></li>
                            <li class="nav-item"><a class="nav-link px-3" href="/repair/create">Nová oprava</a></li>
                        </ul>
                    {% endif %}

                    {# Submenu Spravovat #}
                    {% if session.user.role == 'admin' %}
                        <ul class="navbar-nav mx-auto mb-2 mb-lg-0 fw-semibold d-none" id="nav-manage">
                            <li class="nav-item"><a class="nav-link px-3" href="/manage/employees">Zaměstnanci</a></li>
                            <li class="nav-item"><a class="nav-link px-3" href="/manage/price-list">Ceník</a></li>
                            <li class="nav-item"><a class="nav-link px-3" href="/manage/assignments">Přidělování</a></li>
                        </ul>
                    {% endif %}
                </div>
            </div>
        </nav>
        {% endif %}
    </header>

    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const path = window.location.pathname;

            const secondaryNav = document.getElementById('secondary-nav');
            const navDefault = document.getElementById('nav-default');
            const navInvoice = document.getElementById('nav-invoice');
            const navrepair = document.getElementById('nav-repair');
            const navManage = document.getElementById('nav-manage');

            // 1. Skrytí druhé navigace pro Dashboard a Procházet opravy (chová se jako dashboard)
            if (path === '/dashboard' || path === '/repair/waiting') {
                if (secondaryNav) secondaryNav.classList.add('d-none');
                return;
            }

            // 2. Logika pro zobrazení specifických submenu
            if (path.startsWith('/invoice') || path.startsWith('/repair') || path.startsWith('/manage')) {
                if (navDefault) navDefault.classList.add('d-none');
            }

            if (path.startsWith('/invoice') && navInvoice) {
                navInvoice.classList.remove('d-none');
            } else if (path.startsWith('/repair') && navrepair) {
                navrepair.classList.remove('d-none');
            } else if (path.startsWith('/manage') && navManage) {
                navManage.classList.remove('d-none');
            }
        });
    </script>
{% endblock %}

{# Hlavní blok pro obsah stránky (přepisuje se vždy) #}
<main class="container mt-4">
    {% block content %}{% endblock %}
</main>

{% block footer %}{% endblock %}

{# Zde se načítá Bootstrap JavaScript #}
<script src="/bootstrap/js/bootstrap.bundle.min.js"></script>

{# Logika pro light/dark mode #}
<script src="/js/Base.js"></script>

{# (placeholder pro dodatečné budoucí JS) #}
{% block javascripts %}{% endblock %}

</body>
</html>