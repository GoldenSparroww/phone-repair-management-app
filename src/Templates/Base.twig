<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <script>
        // Tento skript běží okamžitě, aby se předešlo blikání (light/dark)
        (function() {
            const storedTheme = localStorage.getItem('theme');
            const theme = storedTheme || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
            document.documentElement.setAttribute('data-bs-theme', theme);
        })();
    </script>

    {# Titulek stránky - blok pro přepsání v konkrétní šabloně #}
    <title>{% block title %}Default Title{% endblock %}</title>

    {# Zde se načítá Bootstrap CSS #}
    {# Protože adresář Public je kořenem celého webu (tzv. Document Root), musí se použít absolutní cestu začínající lomítkem (/). #}
    <link href="/bootstrap/css/bootstrap.min.css" rel="stylesheet">

    <link href='https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css' rel="stylesheet">

    {# (placeholder pro dodatečné budoucí CSS) #}
    {% block stylesheets %}{% endblock %}
</head>
<body>

{# Navbar/header #}
{% block header %}
    <header>
        <div class="bg-body-tertiary border-bottom py-2">
            <div class="container d-flex flex-wrap justify-content-between align-items-center">
                <a class="navbar-brand fw-bold fs-4" href="/">Lorem ipsum</a>

                <ul class="nav align-items-center">
                    {% if session.user %}
                        <li class="nav-item"><a href="/auth/logout" class="nav-link link-body-emphasis">Odhlásit se</a></li>
                        <li class="nav-item"> {{ session.user.role }} </li>
                    {% else %}
                        <li class="nav-item"><a href="/auth/login" class="nav-link link-body-emphasis">Přihlásit</a></li>
                    {% endif %}
                </ul>
            </div>
        </div>

        <nav class="navbar navbar-expand-lg bg-body-tertiary border-bottom">
            <div class="container">
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav mx-auto mb-2 mb-lg-0 fw-semibold">
                        <li class="nav-item">
                            <a class="nav-link px-3" href="/home/">Domů</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3" href="/program/">Program</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3" href="/publications/">Publikace</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3" href="/contact/">Kontakt</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3" href="/about/">O nás</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
{% endblock %}

{# Hlavní blok pro obsah stránky (přepisuje se vždy) #}
<main class="container mt-4">
    {% block content %}{% endblock %}
</main>

{% block footer %}{% endblock %}

{# Zde se načítá Bootstrap JavaScript #}
<script src="/bootstrap/js/bootstrap.bundle.min.js"></script>

{# Logika pro light/dark mode #}
<script src="/js/Base.js"></script>

{# (placeholder pro dodatečné budoucí JS) #}
{% block javascripts %}{% endblock %}

</body>
</html>