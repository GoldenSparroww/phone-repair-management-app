{% extends "Base.twig" %}

{% block title %}Přidělování oprav{% endblock %}

{% block content %}
    <div class="mb-4">
        <h2 class="mb-1">Přidělování oprav</h2>
        <p class="text-muted">Seznam oprav, které čekají na přiřazení servisnímu technikovi.</p>
    </div>

    {% if error is defined %}
        <div class="alert alert-danger">{{ error }}</div>
    {% endif %}

    <div class="table-responsive shadow-sm rounded">
        <table class="table table-striped table-hover align-middle mb-0">
            <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Zákazník</th>
                <th>Zařízení</th>
                <th>Popis závady</th>
                <th>Zahájení</th>
                <th>Akce: Přiřazení technika</th>
            </tr>
            </thead>
            <tbody>
            {% for repair in repairs %}
                <tr>
                    <td class="fw-bold">{{ repair.id }}</td>
                    <td>
                        {{ repair.device.customer.firstName }} {{ repair.device.customer.lastName }}<br>
                        <small class="text-muted">{{ repair.device.customer.phone }}</small>
                    </td>
                    <td>
                        {{ repair.device.brand }} {{ repair.device.model }}<br>
                        <small class="text-muted">SN: {{ repair.device.serial }}</small>
                    </td>
                    <td>
                        {# Zobrazení zkráceného popisu pro přehlednost #}
                        <span class="d-inline-block text-truncate" style="max-width: 250px;">
                        {{ repair.description }}
                    </span>
                    </td>
                    <td>{{ repair.startDate|date("d.m.Y") }}</td>
                    <td>
                        {# Formulář odesílající POST požadavek na stejnou URL #}
                        <form action="/manage/assignments" method="POST" class="d-flex align-items-center">
                            <input type="hidden" name="repair_id" value="{{ repair.id }}">
                            <select name="technician_id" class="form-select form-select-sm me-2" required>
                                <option value="" disabled selected>Vyberte technika...</option>
                                {% for tech in technicians %}
                                    <option value="{{ tech.id }}">{{ tech.firstName }} {{ tech.lastName }}</option>
                                {% endfor %}
                            </select>
                            <button type="submit" class="btn btn-sm btn-primary text-nowrap">Přiřadit</button>
                        </form>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6" class="text-center py-4 text-muted">
                        Aktuálně nejsou v systému žádné opravy čekající na přiřazení.
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}