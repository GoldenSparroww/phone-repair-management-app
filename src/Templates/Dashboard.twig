{% extends "Base.twig" %}

{% block title %}Dashboard{% endblock %}

{% block content %}
    <h2 class="mb-4">Přehled systému</h2>

    <div class="row">
        <div class="col-md-4">
            <div class="card text-white bg-primary mb-3 shadow-sm">
                <div class="card-body">
                    <h6 class="card-title text-uppercase text-white-50">Opravy za posledních 7 dní</h6>
                    <h1 class="display-4 fw-bold mb-0">{{ countWeek }}</h1>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-white bg-success mb-3 shadow-sm">
                <div class="card-body">
                    <h6 class="card-title text-uppercase text-white-50">Opravy za poslední 1 rok</h6>
                    <h1 class="display-4 fw-bold mb-0">{{ countYear }}</h1>
                </div>
            </div>
        </div>
    </div>
{% endblock %}