{% extends "Base.twig" %}

{% block title %}Vystavení faktury{% endblock %}

{% block content %}
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0">Nová faktura</h4>
                </div>
                <div class="card-body">
                    <form action="/invoice/create" method="POST">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Vyberte opravu k fakturaci</label>
                            <select name="repair_id" class="form-select" required>
                                <option value="" disabled selected>-- Hotové opravy --</option>
                                {% for repair in repairs %}
                                    <option value="{{ repair.id }}">
                                        #{{ repair.id }} - {{ repair.device.brand }} {{ repair.device.model }} ({{ repair.device.customer.lastName }})
                                    </option>
                                {% endfor %}
                            </select>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Forma platby</label>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="method" id="cash" value="Hotově" checked>
                                <label class="form-check-label" for="cash">Hotově</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="method" id="card" value="Kartou">
                                <label class="form-check-label" for="card">Kartou</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="method" id="transfer" value="Převodem">
                                <label class="form-check-label" for="transfer">Bankovní převod</label>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-success w-100">
                            Vystavit fakturu a uzavřít opravu
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
{% endblock %}